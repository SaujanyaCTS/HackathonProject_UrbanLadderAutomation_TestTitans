<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    parallel="tests" = each <test> block runs in its own thread
    thread-count="2" = Chrome + Edge run at the same time
-->
<suite name="Urban Ladder Test Suite" parallel="tests" thread-count="2">

	<!-- TestListener: takes screenshots on pass/fail/skip + logs to
	ExtentReports -->
	<listeners>
		<listener class-name="com.hackathonproject.listeners.TestListener" />
	</listeners>

	<!-- ========== CHROME TESTS ========== -->
	<test name="Chrome Tests">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.hackathonproject.tests.BookshelvesTest" />
			<class name="com.hackathonproject.tests.CollectionsTest" />
			<class name="com.hackathonproject.tests.GiftCardTest" />
		</classes>
	</test>

